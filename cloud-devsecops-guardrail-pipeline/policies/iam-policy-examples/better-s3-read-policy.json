{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BetterS3ReadOnlyExample",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::training-private-bucket-example",
        "arn:aws:s3:::training-private-bucket-example/*"
      ]
    }
  ]
}
